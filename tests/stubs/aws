#!/usr/bin/env bash
# Hermetic fake `aws` for the ghshot bats tests. NO network.
# Only the subcommands the s3 backend uses are implemented.
#   AWS_STUB_LOG=path   append each invocation's args to this file
set -u

[ -n "${AWS_STUB_LOG:-}" ] && printf '%s\n' "$*" >>"$AWS_STUB_LOG"

case "${1:-} ${2:-}" in
  "s3 cp") exit 0 ;;
  "s3 presign")
    printf 'https://example.com/presigned-object\n'
    exit 0
    ;;
  *) exit 0 ;;
esac
