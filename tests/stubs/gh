#!/usr/bin/env bash
# Hermetic fake `gh` for the ghshot bats tests. NO network.
#
# Behavior is tunable via env vars so individual tests can simulate states:
#   GH_STUB_USER          login returned by `gh api user -q .login`   (default: octocat)
#   GH_STUB_NWO           value for `gh repo view --json nameWithOwner` (default: octocat/demo)
#   GH_STUB_VISIBILITY    value for `gh repo view --json visibility`   (default: PUBLIC)
#   GH_STUB_BRANCH        value for `gh repo view --json defaultBranchRef` (default: main)
#   GH_STUB_AUTH_FAIL=1   make `gh auth status` exit non-zero
#   GH_STUB_REPO_MISSING=1    make `gh repo view <repo>` exit non-zero (repo absent)
#   GH_STUB_RELEASE_MISSING=1 make `gh release view` exit non-zero (release absent)
#   GH_STUB_LOG=path      append each invocation's args to this file
set -u

[ -n "${GH_STUB_LOG:-}" ] && printf '%s\n' "$*" >>"$GH_STUB_LOG"

cmd="${1:-}"
sub="${2:-}"
all="$*"

case "$cmd" in
  auth)
    # gh auth status
    exit "${GH_STUB_AUTH_FAIL:-0}"
    ;;

  api)
    case "$all" in
      *"user -q .login"* | "api user"*)
        printf '%s\n' "${GH_STUB_USER:-octocat}"
        exit 0
        ;;
      *contents*)
        # repos/<owner>/<repo>/contents/README.md --method PUT ...
        exit 0
        ;;
      *)
        exit 0
        ;;
    esac
    ;;

  repo)
    case "$sub" in
      view)
        [ "${GH_STUB_REPO_MISSING:-0}" = 1 ] && exit 1
        case "$all" in
          *"--json nameWithOwner"*)
            printf '%s\n' "${GH_STUB_NWO:-octocat/demo}"
            exit 0
            ;;
          *"--json visibility"*)
            printf '%s\n' "${GH_STUB_VISIBILITY:-PUBLIC}"
            exit 0
            ;;
          *"--json defaultBranchRef"*)
            printf '%s\n' "${GH_STUB_BRANCH:-main}"
            exit 0
            ;;
          *) exit 0 ;;
        esac
        ;;
      create) exit 0 ;;
      *) exit 0 ;;
    esac
    ;;

  release)
    case "$sub" in
      view) exit "${GH_STUB_RELEASE_MISSING:-0}" ;;
      create) exit 0 ;;
      upload) exit 0 ;;
      *) exit 0 ;;
    esac
    ;;

  pr | issue)
    case "$sub" in
      view)
        # gh pr view --json number -q .number  → current branch's PR
        printf '%s\n' "${GH_STUB_PR:-99}"
        exit 0
        ;;
      list)
        # gh pr list ... -q '.[] | "#\(.number)\t..."'  (used by --pick)
        printf '#101\tfeature-x\tAdd X\n#102\tfix-y\tFix Y\n'
        exit 0
        ;;
      comment | *)
        # gh <pr|issue> comment <N> ... --body-file -  → consume stdin, succeed
        cat >/dev/null 2>&1 || true
        exit 0
        ;;
    esac
    ;;

  *)
    exit 0
    ;;
esac
