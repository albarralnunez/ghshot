{
  "manifest_version": 3,
  "name": "ghshot",
  "version": "0.1.0",
  "description": "Uploads images to GitHub user-attachments through your existing github.com session so they render inline even on private repos.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://github.com/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ghshot",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
